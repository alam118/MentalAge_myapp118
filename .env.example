# 🧠 Mental Age Test - Environment Configuration
# Copy this file to .env and replace the placeholder values with your actual keys.
# DO NOT commit your actual .env file to version control.

# ==========================================
# 🤖 AI CONFIGURATION
# ==========================================
# OpenRouter API Key (Required for generating Mental Age & Personality results)
# Get your key at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# ==========================================
# 📱 APP CONFIGURATION
# ==========================================
VITE_APP_NAME="Mental Age Test"
VITE_APP_VERSION="1.0.0"
VITE_APP_URL="http://localhost:3000"

# ==========================================
# 💰 MONETIZATION (AdMob / Custom Ad Network IDs)
# ==========================================
# Replace these with real Ad Unit IDs for production
VITE_BANNER_AD_UNIT_ID=ca-app-pub-3940256099942544/6300978111
VITE_REWARDED_AD_UNIT_ID=ca-app-pub-3940256099942544/5224354917
VITE_NATIVE_AD_UNIT_ID=ca-app-pub-3940256099942544/2247696110
