/**
 * Refined Loader Component
 * Advanced AI-themed loader with spinning particles and glow effects.
 */

import React from 'react';
import styled, { keyframes } from 'styled-components';
import { theme } from '@/styles/theme';

interface LoaderProps {
  title?: string;
  fullScreen?: boolean;
}

const Loader: React.FC<LoaderProps> = ({ title = "AI is thinking...", fullScreen = false }) => {
  return (
    <Wrapper fullScreen={fullScreen}>
      <BrainContainer>
        <Core />
        <Ring delay={0} />
        <Ring delay={0.5} />
        <Ring delay={1} />
        <Particle orbit={1} />
        <Particle orbit={2} />
        <Particle orbit={3} />
      </BrainContainer>
      <LoadingText>{title}</LoadingText>
    </Wrapper>
  );
};

const pulse = keyframes`
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.2); opacity: 1; }
`;

const rotate = keyframes`
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
`;

const Wrapper = styled.div<{ fullScreen: boolean }>`
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  ${({ fullScreen }) => fullScreen && `
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: ${theme.colors.background};
    z-index: ${theme.zIndices.modal};
  `}
`;

const BrainContainer = styled.div`
  position: relative;
  width: 120px;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
`;

const Core = styled.div`
  width: 30px;
  height: 30px;
  background: ${theme.colors.accent};
  border-radius: 50%;
  filter: blur(8px);
  animation: ${pulse} 1.5s infinite;
`;

const Ring = styled.div<{ delay: number }>`
  position: absolute;
  width: 100%;
  height: 100%;
  border: 1px solid ${theme.colors.accent};
  border-radius: 50%;
  opacity: 0.1;
  animation: ${pulse} 2s infinite;
  animation-delay: ${({ delay }) => delay}s;
`;

const Particle = styled.div<{ orbit: number }>`
  position: absolute;
  width: 6px;
  height: 6px;
  background: ${theme.colors.accent};
  border-radius: 50%;
  box-shadow: 0 0 10px ${theme.colors.accent};
  
  offset-path: path('M 60,0 A 60,60 0 1,1 60,120 A 60,60 0 1,1 60,0');
  animation: ${rotate} ${({ orbit }) => 2 + orbit}s linear infinite;
`;

const LoadingText = styled.div`
  font-family: ${theme.typography.fontFamily.heading};
  font-size: ${theme.typography.fontSizes.md};
  color: ${theme.colors.accent};
  letter-spacing: 2px;
  text-transform: uppercase;
`;

export default Loader;
